# Konfigurasi Server
PORT=5000
NODE_ENV=development

# Konfigurasi Database (MySQL)
# Gunakan 'localhost' jika menjalankan node di lokal laptop
# Gunakan 'mysql-db' (nama service di docker-compose) jika menjalankan di dalam Docker
DB_HOST=mysql-db
DB_PORT=3307
DB_USER=root
DB_PASS=password_aman
DB_NAME=db_lomba

# Konfigurasi JWT (Untuk login admin nantinya)
JWT_SECRET=rahasia_sangat_kuat_123
JWT_EXPIRES_IN=30d

# URL Frontend (Untuk keperluan CORS)
FRONTEND_URL=http://localhost:5173